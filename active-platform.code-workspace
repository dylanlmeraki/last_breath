{
	"folders": [
		{
			"path": ".",
			"name": "repo-root (config only)"
		},
		{
			"path": "attached_assets",
			"name": "attached_assets"
		},
		{
			"path": "client/src/components/shared",
			"name": "shared-components"
		},
		{
			"path": "client/src/hooks",
			"name": "hooks"
		},
		{
			"path": "client/src/lib",
			"name": "client-lib"
		},
		{
			"path": "client/src/portals/marketing",
			"name": "marketing"
		},
		{
			"path": "client/src/portals/client",
			"name": "client-portal"
		},
		{
			"path": "client/src/portals/internal",
			"name": "internal-portal"
		},
		{
			"path": "server",
			"name": "server"
		},
		{
			"path": "shared",
			"name": "shared"
		}
	],
	"settings": {
		"files.exclude": {
			"**/node_modules": true,
			"**/dist": true,
			"**/.git": true,
			"artifacts/**": true
		},
		"search.exclude": {
			"**/node_modules": true,
			"**/dist": true,
			"artifacts/**": true
		},
		"git.ignoreLimitWarning": true,
		"mcpFigma.aiAssistant": "manual",
		"mcpFigma.autoStartWebSocket": true,
		"chatgpt.openOnStartup": true,
		"mcp": {
			"inputs": [
				{
					"id": "token",
					"type": "promptString",
					"description": "",
					"password": true
				}
			],
			"servers": {
				"com.figma.mcp/mcp": {
					"type": "http",
					"url": "https://mcp.figma.com/mcp",
					"gallery": "https://api.mcp.github.com",
					"version": "1.0.3"
				},
				"io.github.microsoft/awesome-copilot": {
					"type": "stdio",
					"command": "docker",
					"args": [
						"-y",
						"run",
						"-i",
						"--rm",
						"ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:1.0.2026040123"
					],
					"gallery": "https://api.mcp.github.com",
					"version": "1.0.2026040123"
				}
			}
		}
	},
	"mcp": {
		"servers": {
			"io.github.upstash/context7": {
				"type": "stdio",
				"command": "npx",
				"args": [
					"@upstash/context7-mcp@1.0.31"
				],
				"env": {
					"CONTEXT7_API_KEY": "${input:CONTEXT7_API_KEY}"
				},
				"gallery": "https://api.mcp.github.com",
				"version": "1.0.31"
			},
			"io.github.microsoft/awesome-copilot": {
				"type": "stdio",
				"command": "docker",
				"args": [
					"run",
					"-i",
					"--rm",
					"ghcr.io/microsoft/mcp-dotnet-samples/awesome-copilot:1.0.2026040100"
				],
				"gallery": "https://api.mcp.github.com",
				"version": "1.0.2026040100"
			},
			"io.github.github/github-mcp-server": {
				"type": "stdio",
				"command": "docker",
				"args": [
					"run",
					"-i",
					"--rm",
					"-e",
					"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
					"ghcr.io/github/github-mcp-server:0.33.0"
				],
				"gallery": "https://api.mcp.github.com",
				"version": "0.33.0"
			},
			"com.figma.mcp/mcp": {
				"type": "http",
				"url": "https://mcp.figma.com/mcp",
				"gallery": "https://api.mcp.github.com",
				"version": "1.0.3"
			},
			"microsoft/playwright-mcp": {
				"type": "stdio",
				"command": "npx",
				"args": [
					"@playwright/mcp@latest"
				],
				"gallery": "https://api.mcp.github.com",
				"version": "0.0.1-seed"
			}
		}
	},
	"inputs": [
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}